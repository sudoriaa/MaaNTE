{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "异环小助手，由MAAFramework强力驱动！",
    "contact": "QQ群: 1103323319",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAANTE!",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "version": "0.0.1",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "异环",
                "screencap": "FramePool",
                "mouse": "Seize",
                "keyboard": "Seize"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "./resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "钓鱼",
            "entry": "AutoFish",
            "option": [
                "钓鱼次数"
            ],
            "description": "异环自动钓鱼"
        },
        {
            "name": "领取一咖舍收益",
            "entry": "领取一咖舍收益"
        },
        {
            "name": "自动做咖啡",
            "entry": "AutoMakeCoffee",
            "option": [
                "循环次数"
            ]
        }
    ],
    "option": {
        "钓鱼次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "钓鱼次数",
                    "default": "100",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoFish": {
                    "custom_action_param": {
                        "count": "{钓鱼次数}"
                    }
                }
            }
        },
        "循环次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "循环次数",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoMakeCoffee": {
                    "custom_action_param": {
                        "count": "{循环次数}"
                    }
                }
            }
        }
    }
}