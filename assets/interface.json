{
    "interface_version": 2,
    "name": "MaaNTE",
    "description": "异环小助手，由MAAFramework强力驱动！",
    "contact": "QQ群: 1103323319",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MaaNTE!",
    "github": "https://github.com/1bananachicken/MaaNTE",
    "version": "0.0.1",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "^\\s*异环\\s*$",
                "screencap": "FramePool",
                "mouse": "Seize",
                "keyboard": "PostMessageWithWindowPos"
            }
        }
    ],
    "resource": [
        {
            "name": "官服",
            "path": [
                "resource/base"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "钓鱼任务",
            "entry": "StartFishing",
            "option": [
                "钓鱼循环次数",
                "钓鱼数量",
                "自动卖鱼",
                "自动买鱼饵"
            ]
        },
        {
            "name": "领取一咖舍收益",
            "entry": "领取一咖舍收益"
        },
        {
            "name": "自动做咖啡",
            "entry": "AutoMakeCoffee",
            "option": [
                "循环次数"
            ]
        }
    ],
    "option": {
        "钓鱼循环次数": {
            "type": "input",
            "label": "最大循环次数",
            "description": "限制整个钓鱼循环最多执行多少次",
            "inputs": [
                {
                    "name": "max_hit",
                    "label": "循环次数",
                    "default": "5",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "StartFishing": {
                    "max_hit": "{max_hit}"
                }
            }
        },
        "钓鱼数量": {
            "type": "input",
            "label": "每次钓鱼数量",
            "description": "设置每次自动钓鱼的数量",
            "inputs": [
                {
                    "name": "count",
                    "label": "数量",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^\\d+$"
                }
            ],
            "pipeline_override": {
                "AutoFish": {
                    "custom_action_param": {
                        "count": "{count}"
                    }
                }
            }
        },
        "自动卖鱼": {
            "type": "switch",
            "label": "自动卖鱼",
            "description": "是否启用自动卖鱼功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoSellFish": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "自动买鱼饵": {
            "type": "switch",
            "label": "自动买鱼饵",
            "description": "是否启用自动买鱼饵功能",
            "cases": [
                {
                    "name": "Yes",
                    "label": "启用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": true
                        }
                    }
                },
                {
                    "name": "No",
                    "label": "禁用",
                    "pipeline_override": {
                        "AutoBuyFishBait": {
                            "enabled": false
                        }
                    }
                }
            ]
        },
        "循环次数": {
            "type": "input",
            "inputs": [
                {
                    "name": "循环次数",
                    "default": "10",
                    "pipeline_type": "int"
                }
            ],
            "pipeline_override": {
                "AutoMakeCoffee": {
                    "custom_action_param": {
                        "count": "{循环次数}"
                    }
                }
            }
        }
    }
}